DATABASE_URL=postgresql://dramacommerce:dramacommerce@localhost:5432/dramacommerce
REDIS_URL=redis://localhost:6379

# The web app never calls BullMQ directly — it writes an outbox_events row
# in the same Postgres transaction as the domain state (showrunner_jobs/
# video_jobs/final_videos), and the outbox dispatcher (pnpm run
# worker:outbox / start:outbox) is the only process that publishes to
# Redis/BullMQ. All optional, sane defaults for local dev.
# How often the dispatcher polls Postgres for pending events.
OUTBOX_DISPATCH_INTERVAL_MS=2000
# Max events claimed per poll tick.
OUTBOX_DISPATCH_BATCH_SIZE=25
# Backoff after a failed dispatch attempt: base * 2^(attempts-1), capped at max.
OUTBOX_DISPATCH_BASE_BACKOFF_MS=2000
OUTBOX_DISPATCH_MAX_BACKOFF_MS=300000
# Attempts before a permanently-failing event is marked FAILED instead of retried.
OUTBOX_DISPATCH_MAX_ATTEMPTS=10
# How often the dispatcher deletes old DELIVERED/FAILED events (retention).
OUTBOX_CLEANUP_INTERVAL_MS=3600000
OUTBOX_DELIVERED_RETENTION_MS=86400000
OUTBOX_FAILED_RETENTION_MS=1209600000
# /health reports the outbox check as unhealthy once the oldest pending
# event is older than this — a proxy for "the dispatcher isn't running",
# since there's no direct way to ping a separate process.
OUTBOX_HEALTH_STALE_THRESHOLD_SECONDS=120
# If a worker crashes after flipping a scene to RUNNING but before saving
# Wan's task_id, a retry within this window is treated as a likely
# in-flight duplicate and skipped; beyond it, the retry proceeds instead of
# leaving the scene stuck forever. See CLAUDE.md for the full tradeoff.
WAN_TASK_STALE_RUNNING_GRACE_MS=300000
# --- External request timeouts & retry classification ---------------------
# Every server/worker call to Qwen, Wan, DashScope TTS, OSS, and remote media
# URLs goes through app/services/http/http-client.server.ts (mirrored in
# scripts/lib/http-client.mjs for the plain-JS video worker) — a shared
# fetch wrapper with AbortSignal.timeout, bounded response reads, streaming
# downloads with a hard size cap, and classified errors (timeout/network/
# rate_limit/auth_config/server_temporary/invalid_response/oversized_response/
# permanent_client). Workers use that classification to skip BullMQ's
# remaining retry attempts (via UnrecoverableError) for errors retrying can
# never fix — bad API key, invalid URL protocol, malformed provider
# response, oversized download, missing config — while genuinely transient
# failures (network blips, timeouts, 429, 5xx) still retry normally.
#
# All values below are parsed and validated at first use: unset -> the
# default shown; set but non-numeric/zero/negative/absurdly large -> the
# process throws at startup rather than silently running with no timeout.
# Never disable these in production — a provider hang would otherwise
# occupy a worker slot and a DB row indefinitely.

# Qwen chat completions (Story/Director/Prompt/Critic/Editor agents).
QWEN_REQUEST_TIMEOUT_MS=60000
# Qwen vision call (Analyze Agent only) — a single call, no tool-calling rounds.
QWEN_VISION_REQUEST_TIMEOUT_MS=45000
# Wan task *creation* — returns fast since generation itself is async.
# NOTE: a timeout here is ambiguous — Wan may have already accepted and
# started the task before the client gave up waiting. The worker does not
# create a replacement task from a timed-out create call; see CLAUDE.md's
# Reliability section and claimGenerationForWanCall in scripts/video-worker.mjs.
WAN_CREATE_TIMEOUT_MS=30000
# Wan task *status polling* — should be snappy; polled every VIDEO_WORKER
# poll cycle, so a slow timeout here just delays noticing a stuck poll.
WAN_POLL_TIMEOUT_MS=15000
# DashScope TTS voice-over synthesis.
TTS_REQUEST_TIMEOUT_MS=60000
# ali-oss SDK client timeout, used for every OSS operation (put/get/delete/list).
OSS_REQUEST_TIMEOUT_MS=10000
# Bounds each individual dependency check inside /health (database, redis,
# storage, ffmpeg, outbox) so a hung Postgres/Redis/OSS connection can't make
# the health endpoint itself hang. Deliberately shorter than the generation
# timeouts above — /health should fail fast, not wait as long as a real
# generation call would.
HEALTH_CHECK_TIMEOUT_MS=5000

# fetch() timeout / max response size enforced whenever a worker downloads a
# remote file (Wan clip, TTS audio, product image reference) via the shared
# streaming downloader — not applied to storage reads, which have no such
# risk. Downloads exceeding either limit are aborted and any partial file on
# disk is removed.
MEDIA_DOWNLOAD_TIMEOUT_MS=120000
MEDIA_DOWNLOAD_MAX_BYTES=209715200

# "local" (default) stores uploads/generated media under uploads/ on disk —
# fine for a single process, but the web app, showrunner worker, and video
# worker must then share that directory (e.g. a mounted volume) if they run
# as separate containers. "oss" stores media in Alibaba Cloud OSS instead,
# which every container reaches over the network — no shared filesystem
# needed. See README's Docker/Deployment section.
MEDIA_STORAGE_DRIVER=local

# Required when MEDIA_STORAGE_DRIVER=oss.
OSS_REGION=oss-ap-southeast-1
OSS_BUCKET=your-bucket-name
OSS_ACCESS_KEY_ID=xxxxx
OSS_ACCESS_KEY_SECRET=xxxxx
# Optional — override the SDK's region-derived endpoint (e.g. for a private/
# internal OSS endpoint).
OSS_ENDPOINT=
# Optional. Unset (default): objects are private, and the app generates a
# short-lived signed URL per request — works with a private bucket, no extra
# bucket configuration needed. Set this only if the bucket's objects are
# public-read (bucket ACL or a CDN in front of it) and you'd rather serve
# plain, non-expiring URLs than signed ones.
OSS_PUBLIC_BASE_URL=
# Optional — signed URL lifetime in seconds (default 3600). Only relevant
# when OSS_PUBLIC_BASE_URL is unset.
OSS_SIGNED_URL_EXPIRES_SECONDS=3600

DASHSCOPE_API_KEY=sk-xxxxx
QWEN_BASE_URL=https://YOUR_WORKSPACE_ID.ap-southeast-1.maas.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
# Vision model for the Analyze Agent — same base URL/key as QWEN_BASE_URL above.
QWEN_VISION_MODEL=qwen3-vl-flash

DASHSCOPE_VIDEO_BASE_URL=https://YOUR_WORKSPACE_ID.ap-southeast-1.maas.aliyuncs.com
WAN_VIDEO_MODEL=wan2.1-t2v-turbo
# Used only for scenes the Director Agent marks useProductReference: true —
# animates from the real uploaded product photo instead of a text prompt.
WAN_VIDEO_I2V_MODEL=wan2.1-i2v-turbo
WAN_VIDEO_RESOLUTION=720P
WAN_VIDEO_RATIO=9:16
WAN_VIDEO_DURATION=5

# Usually the same value as DASHSCOPE_VIDEO_BASE_URL (same DashScope
# workspace), kept as its own var since it's a separate DashScope surface.
DASHSCOPE_TTS_BASE_URL=https://YOUR_WORKSPACE_ID.ap-southeast-1.maas.aliyuncs.com
DASHSCOPE_TTS_MODEL=qwen3-tts-flash
DASHSCOPE_TTS_VOICE=Cherry

RATE_LIMIT_GENERATE_PER_USER_WINDOW_MINUTES=10
RATE_LIMIT_GENERATE_PER_USER_MAX=5
RATE_LIMIT_GENERATE_GLOBAL_DAILY_MAX=200

RATE_LIMIT_VIDEO_CREATE_WINDOW_MINUTES=10
RATE_LIMIT_VIDEO_CREATE_MAX=10
RATE_LIMIT_VIDEO_STITCH_WINDOW_MINUTES=10
RATE_LIMIT_VIDEO_STITCH_MAX=5

# Generate with: npx auth secret
AUTH_SECRET=changeme

# Google Cloud Console > APIs & Services > Credentials > OAuth client ID (Web application).
# Register these Authorized redirect URIs:
#   http://localhost:3000/auth/callback/google (local dev)
#   https://YOUR_DOMAIN/auth/callback/google (production)
AUTH_GOOGLE_ID=xxxxx.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=xxxxx
