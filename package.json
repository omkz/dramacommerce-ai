    "bullmq": "^5.79.2",
    "drizzle-orm": "^0.45.2",
    "file-type": "^22.0.1",
    "ioredis": "^5.11.1",
    "isbot": "^5.1.36",
    "pg": "^8.22.0",
    "rate-limiter-flexible": "^11.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "8.0.0",
    "tsx": "^4.22.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@react-router/dev": "8.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
